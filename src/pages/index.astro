---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sam Onishi | Organizational Operations & Venture Support"
  description="Business and operations professional supporting founders and organizations in multilingual, cross-cultural environments."
  wide
>
  <article class="hero-page">
    <div class="hero-content">
      <p class="eyebrow">Operational Partner Profile</p>
      <h1 class="hero-title">Sam Onishi</h1>
      <div class="hero-role">
        <span class="role-main">Business Manager</span>
        <span class="role-divider">/</span>
        <span class="role-sub">Organizational Operations &amp; Venture Support</span>
        <span class="langs">(JA / EN / KO)</span>
      </div>
      <blockquote class="hero-lead">
        Supporting founders, organizations, and creative initiatives in cross-cultural
        and multilingual environments—with a focus on structure, execution, and continuity.
      </blockquote>
      <ul class="hero-tags" aria-label="Focus areas">
        <li>Organizational Operations</li>
        <li>Venture Support</li>
        <li>Localization &amp; Documentation</li>
      </ul>
      <nav class="hero-cta" aria-label="Next steps">
        <a href="/about/" class="cta-link cta-primary">About Sam</a>
        <a href="/work/" class="cta-link">Work &amp; Background</a>
      </nav>
    </div>
    <div class="hero-visual-wrap" aria-hidden="true">
      <div class="hero-visual">
        <img src="/hero-right.jpeg" alt="" width="800" height="600" />
        <span class="hero-caption">Cross-cultural execution in high-tempo environments</span>
      </div>
    </div>
  </article>

  <section class="context-strip" aria-label="Context of work">
    <div class="context-grid">
      <figure class="context-card context-card--wide">
        <div class="context-card-inner">
          <img src="/ABT-Web-Tile.png" alt="" width="800" height="600" />
          <figcaption>Creative &amp; cultural initiatives</figcaption>
        </div>
      </figure>
      <figure class="context-card">
        <div class="context-card-inner">
          <img src="/500px-MCI_equipped_Studiod.jpg" alt="" width="600" height="400" />
          <figcaption>Execution &amp; production support</figcaption>
        </div>
      </figure>
    </div>
  </section>

  <style>
    .hero-page {
      display: grid;
      grid-template-columns: 1fr minmax(280px, 0.9fr);
      gap: clamp(2rem, 5vw, 4rem);
      align-items: center;
      padding-top: 0.5rem;
    }

    .hero-content {
      min-width: 0;
      max-width: 42rem;
    }

    .eyebrow {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 0.85rem;
    }

    .hero-title {
      font-family: var(--font-serif);
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 400;
      line-height: 1.05;
      margin: 0;
      color: var(--text);
      letter-spacing: -0.02em;
    }

    .hero-role {
      margin-top: 0.6rem;
      font-size: 0.95rem;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.35rem 0.5rem;
    }

    .role-main {
      font-weight: 600;
      color: var(--text);
    }

    .role-divider {
      color: var(--line);
      font-weight: 300;
      margin-right: 0.15rem;
    }

    .role-sub {
      color: var(--muted);
      font-weight: 500;
    }

    .langs {
      font-weight: 400;
      color: var(--muted-light);
      font-size: 0.9em;
    }

    .hero-lead {
      margin: 1.5rem 0 0;
      padding-left: 1.25rem;
      border-left: 2px solid var(--line);
      font-family: var(--font-serif);
      font-size: 1.05rem;
      font-style: italic;
      line-height: 1.65;
      color: var(--muted);
      max-width: 40ch;
    }

    .hero-tags {
      list-style: none;
      margin: 1.5rem 0 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0;
    }

    .hero-tags li {
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--accent-hover);
    }

    .hero-tags li + li::before {
      content: ' · ';
      padding: 0 0.35rem 0 0;
      color: var(--muted-light);
      font-weight: 400;
    }

    .hero-cta {
      display: flex;
      flex-wrap: wrap;
      gap: 1.25rem;
      margin-top: 1.75rem;
    }

    .cta-link {
      font-size: 0.95rem;
      font-weight: 500;
      transition: color 0.15s ease, opacity 0.15s ease;
    }

    .cta-link::after {
      content: ' →';
      opacity: 0.6;
      transition: opacity 0.15s ease;
    }

    .cta-link:hover::after {
      opacity: 1;
    }

    .cta-primary {
      color: var(--accent);
    }

    .cta-primary:hover {
      color: var(--accent-hover);
    }

    .hero-cta .cta-link:not(.cta-primary) {
      color: var(--muted);
    }

    .hero-cta .cta-link:not(.cta-primary):hover {
      color: var(--text);
    }

    /* Hero image: layered frame with offset */
    .hero-visual-wrap {
      position: relative;
    }

    .hero-visual {
      position: relative;
      border-radius: var(--radius);
      overflow: hidden;
      background: var(--line);
      aspect-ratio: 4/3;
      max-height: 400px;
      box-shadow:
        0 0 0 1px rgba(0, 0, 0, 0.04),
        0 4px 6px -1px rgba(0, 0, 0, 0.06),
        0 20px 40px -12px rgba(0, 0, 0, 0.12);
      transform: translate(0, 0);
    }

    .hero-visual::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(28, 25, 23, 0.35) 0%,
        transparent 40%
      );
      pointer-events: none;
      z-index: 1;
    }

    .hero-visual-wrap::after {
      content: '';
      position: absolute;
      right: -0.75rem;
      bottom: -0.75rem;
      width: 100%;
      height: 100%;
      border-radius: var(--radius);
      border: 1px solid var(--line);
      background: transparent;
      z-index: -1;
    }

    .hero-visual img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      display: block;
    }

    .hero-caption {
      position: absolute;
      left: 1.25rem;
      bottom: 1.25rem;
      padding: 0.4rem 0.85rem;
      border-radius: 999px;
      background: rgba(28, 25, 23, 0.72);
      backdrop-filter: blur(8px);
      color: #fafaf9;
      font-size: 0.78rem;
      font-weight: 500;
      z-index: 2;
    }

    @media (max-width: 860px) {
      .hero-page {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .hero-visual-wrap {
        order: -1;
      }

      .hero-visual {
        max-height: 280px;
      }

      .hero-visual-wrap::after {
        right: -0.5rem;
        bottom: -0.5rem;
      }
    }

    /* Context strip: two new images */
    .context-strip {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--line);
    }

    .context-grid {
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 1.25rem;
    }

    .context-card {
      margin: 0;
      position: relative;
      border-radius: var(--radius);
      overflow: hidden;
      background: var(--line);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .context-card-inner {
      position: relative;
      aspect-ratio: 4/3;
      overflow: hidden;
    }

    .context-card--wide .context-card-inner {
      aspect-ratio: 16/10;
    }

    .context-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .context-card--wide img {
      object-position: center 25%;
    }

    .context-card img[src*="MCI"] {
      object-position: center 40%;
    }

    .context-card figcaption {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      padding: 1rem 1.25rem;
      background: linear-gradient(to top, rgba(28, 25, 23, 0.82), transparent);
      color: #fafaf9;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.02em;
    }

    @media (max-width: 720px) {
      .context-strip {
        margin-top: 3rem;
        padding-top: 1.5rem;
      }

      .context-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .context-card--wide .context-card-inner {
        aspect-ratio: 4/3;
      }
    }
  </style>
</BaseLayout>
