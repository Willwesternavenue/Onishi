---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Sam Onishi"
  description="Get in touch for inquiries about organizational operations, venture support, or collaboration."
>
  <article class="page-content contact-page">
    <header class="page-header">
      <h1>Contact</h1>
      <p class="lead">For inquiries regarding organizational operations, venture support, or collaboration.</p>
    </header>

    <div class="contact-block">
      <p class="contact-email">
        <a href="mailto:contact@samonishi.com">contact@samonishi.com</a>
      </p>
      <p class="contact-note">
        For updated professional information and background, please refer to
        <a href="https://www.linkedin.com/in/samonishi" target="_blank" rel="noopener noreferrer">LinkedIn</a>.
      </p>
    </div>
  </article>

  <style>
    .page-header {
      margin-bottom: 2rem;
    }

    .page-header h1 {
      font-family: var(--font-serif);
      font-size: clamp(2rem, 3vw, 2.5rem);
      font-weight: 400;
      margin: 0;
      color: var(--text);
    }

    .page-header .lead {
      margin: 0.5rem 0 0;
      font-size: 1.1rem;
      color: var(--muted);
    }

    .contact-block {
      max-width: 40ch;
    }

    .contact-email {
      font-size: 1.15rem;
      margin: 0;
    }

    .contact-email a {
      font-weight: 600;
      color: var(--accent);
    }

    .contact-email a:hover {
      color: var(--accent-hover);
    }

    .contact-note {
      margin: 1.25rem 0 0;
      font-size: 0.95rem;
      color: var(--muted);
    }
  </style>
</BaseLayout>
