---
const links = [
  { href: '#top', label: 'Top' },
  { href: '#about', label: 'About' },
  { href: '#work', label: 'Work' },
  { href: '#contact', label: 'Contact' },
];
---

<nav class="nav" aria-label="Main">
  <a class="nav-logo" href="#top">Sam Onishi</a>
  <ul class="nav-links">
    {links.map(({ href, label }) => (
      <li><a href={href}>{label}</a></li>
    ))}
  </ul>
</nav>
