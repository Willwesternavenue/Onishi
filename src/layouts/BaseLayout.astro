---
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Business and operations professional supporting founders and organizations in multilingual, cross-cultural environments.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://samonishi.com').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonical} />

    <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Sam Onishi',
        url: 'https://samonishi.com',
        jobTitle: 'Organizational Operations & Venture Support',
        knowsLanguage: ['Japanese', 'English', 'Korean']
      })} />

    <style is:global>
      html {
        scroll-behavior: smooth;
      }
      :root {
        --bg: #f5f7f9;
        --surface: #ffffff;
        --text: #2c3e50;
        --muted: #5d6d7e;
        --muted-light: #95a5a6;
        --line: #d5dbdb;
        --accent: #1f5e95;
        --accent-hover: #154360;
        --accent-soft: #e8f4fc;
        --maxw: 720px;
        --radius: 8px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 1rem;
        line-height: 1.65;
        color: var(--text);
        background: var(--bg);
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s ease;
      }
      a:hover {
        color: var(--accent-hover);
      }

      .layout {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .nav-wrap {
        border-bottom: 1px solid var(--line);
        background: var(--surface);
      }

      .nav {
        width: min(100% - 2rem, var(--maxw));
        margin-inline: auto;
        padding: 1rem 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
      }

      .nav-logo {
        font-family: Georgia, serif;
        font-size: 1.25rem;
        font-weight: 400;
        color: var(--text);
      }

      .nav-logo:hover {
        color: var(--text);
      }

      .nav-links {
        display: flex;
        gap: 1.75rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .nav-links a {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--muted);
      }

      .nav-links a:hover,
      .nav-links a[aria-current="page"] {
        color: var(--text);
      }

      .nav-links a[aria-current="page"] {
        font-weight: 600;
      }

      main {
        flex: 1;
        width: min(100% - 2rem, var(--maxw));
        margin-inline: auto;
        padding: 1.5rem 0 3rem;
      }

      .footer-wrap {
        border-top: 1px solid var(--line);
        background: var(--surface);
        margin-top: auto;
      }

      .footer {
        width: min(100% - 2rem, var(--maxw));
        margin-inline: auto;
        padding: 1.25rem 0;
        text-align: center;
        font-size: 0.875rem;
        color: var(--muted);
      }

      @media (max-width: 640px) {
        .nav {
          flex-direction: column;
          align-items: flex-start;
          padding: 0.875rem 0;
        }

        .nav-links {
          gap: 1.25rem;
        }

        main {
          padding: 1.5rem 0 3rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <header class="nav-wrap">
        <Nav />
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer-wrap">
        <div class="footer">
          <span>&copy; 2009 Sam Onishi</span>
        </div>
      </footer>
    </div>
  </body>
</html>
